# Default mode for window navigation
# managewin mode for window placement and resizing
:: managewin @
:: applaunch @

cmd + alt + ctrl - v ; applaunch

managewin, applaunch < escape ; default

# stop/start/restart yabai
cmd + alt + ctrl - q : yabai --stop-service
cmd + alt + ctrl - s : yabai --start-service
cmd + alt + ctrl - r : yabai --restart-service
